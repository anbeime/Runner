[project]
entrypoint = "index.html"
requires = [ "nodejs-24" ]
template = "native-static"
version = "0.0.21"
appliedPatches = [ ]

[dev]
build = [ "pnpm", "add", "-g", "serve" ]
run = [ "sh", "-c", "cd \"$COZE_WORKSPACE_PATH\" && npx serve -l \"$DEPLOY_RUN_PORT\" --no-clipboard" ]

[deploy]
build = [ "pnpm", "add", "-g", "serve" ]
run = [ "sh", "-c", "npx serve -l \"$DEPLOY_RUN_PORT\" --no-clipboard" ]
